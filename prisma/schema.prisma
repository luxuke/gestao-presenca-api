generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  nome         String
  email        String        @unique
  senha        String
  createdAt    DateTime      @default(now())
  appointments Appointment[]
}

model Appointment {
  id          Int      @id @default(autoincrement())
  titulo      String
  descricao   String
  data        DateTime
  status      String   @default("PENDENTE")
  prioridade  String   @default("NORMAL")
  createdAt   DateTime @default(now())

  userId      Int
  user        User @relation(fields: [userId], references: [id])
}

model WaitingList {
  id          Int      @id @default(autoincrement())
  nome        String
  prioridade  String   @default("NORMAL")
  status      String   @default("AGUARDANDO")
  createdAt   DateTime @default(now())
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  acao        String
  descricao   String
  createdAt   DateTime @default(now())
}